{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- style -%}
  /* 1. DECLARE THE CUSTOM FONT */
  @font-face {
    font-family: 'Chillax-Custom';
    src: url({{ 'Chillax-Variable.woff2' | asset_url }}) format('woff2');
    font-weight: 100 900;
    font-display: swap;
  }

  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    background-color: #1c1c1c; 
    color: #ffffff;
    /* Removed global font-family so theme defaults apply to most text */
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .footer__content-top.page-width {
      display: flex;
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
      gap: 6rem;
    }

    .footer-block--newsletter {
      flex: 0 0 50%; 
      margin-top: 0 !important;
      text-align: left;
    }

    .footer__blocks-wrapper {
      flex: 1;
      display: grid;
      grid-template-columns: repeat(2, 1fr); 
      gap: 3rem;
    }
  }

  /* 2. APPLY CUSTOM FONT TO HEADING ONLY */
  .footer-block__heading {
    font-family: 'Chillax-Custom', sans-serif !important;
    font-size: 4.8rem;
    line-height: 1.1;
    font-weight: 300; 
    text-transform: none;
    letter-spacing: -1px;
    margin-bottom: 3rem;
    text-align: left;
  }

  .footer-block__heading strong {
    font-weight: 700; 
  }

  /* INPUT & OTHER TEXT (Uses Theme Font) */
  .footer .field:after, .footer .field:before {
    content: none !important;
  }

  .footer .field__input {
    border: none !important;
    border-bottom: 1px solid rgba(255,255,255,1) !important;
    background: transparent !important;
    border-radius: 0 !important;
    padding-left: 0 !important;
    box-shadow: none !important;
    color: white;
    height: 4.5rem;
  }

  .footer-block__details-content .list-menu__item--link {
    font-weight: 600;
    font-size: 1.8rem;
    padding: 0.8rem 0;
    color: #fff;
    text-decoration: none;
  }

  .footer-block__heading-small {
    font-size: 1.4rem;
    text-transform: none;
    opacity: 0.5;
    margin-bottom: 2rem;
    text-align: left;
  }

  /* BOTTOM AREA */
  .footer__content-bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    margin-top: 8rem;
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .footer__content-bottom-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  /* 3. APPLY CUSTOM FONT TO LOGO TEXT ONLY */
  .footer-custom-logo h2 {
    font-family: 'Chillax-Custom', sans-serif !important;
    font-size: 3.8rem;
    margin: 0;
    font-weight: 400;
    letter-spacing: -1.5px;
  }

  .footer-bottom-links {
    display: flex;
    gap: 3rem;
    font-size: 1.4rem;
    opacity: 0.7;
  }

  .footer-bottom-links a {
    color: inherit;
    text-decoration: none;
  }

{%- endstyle -%}

<footer class="footer color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="footer__content-top page-width">
    
    {%- if section.settings.newsletter_enable -%}
      <div class="footer-block--newsletter">
        <div class="footer-block__newsletter">
          {%- if section.settings.newsletter_heading != blank -%}
            <h2 class="footer-block__heading inline-richtext">{{ section.settings.newsletter_heading }}</h2>
          {%- endif -%}
          
          {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="newsletter-form__field-wrapper">
              <div class="field">
                <input
                  id="NewsletterForm--{{ section.id }}"
                  type="email"
                  name="contact[email]"
                  class="field__input"
                  value="{{ form.email }}"
                  aria-required="true"
                  autocorrect="off"
                  autocapitalize="off"
                  autocomplete="email"
                  placeholder="Email address*"
                  required
                >
                <label class="field__label" for="NewsletterForm--{{ section.id }}">Email address*</label>
                <button type="submit" class="newsletter-form__button field__button" name="commit" id="Subscribe">
                  <span class="svg-wrapper">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </button>
              </div>
              <p style="margin-top: 2rem; opacity: 0.6; font-style: italic; font-size: 1.3rem; text-align: left;">Enjoy 10% off your first purchase on sign up</p>
            </div>
          {%- endform -%}
        </div>
      </div>
    {%- endif -%}

    <div class="footer__blocks-wrapper grid">
      {%- for block in section.blocks -%}
        <div class="footer-block grid__item" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <p class="footer-block__heading-small">{{- block.settings.heading -}}</p>
          {%- endif -%}

          {%- case block.type -%}
            {%- when 'link_list' -%}
              {%- if block.settings.menu != blank -%}
                <ul class="footer-block__details-content list-unstyled">
                  {%- for link in block.settings.menu.links -%}
                    <li>
                      <a href="{{ link.url }}" class="link link--text list-menu__item list-menu__item--link">
                        {{ link.title | escape }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>
  </div>

  <div class="footer__content-bottom">
    <div class="footer__content-bottom-wrapper page-width">
      <div class="footer-custom-logo">
        <h2>backupbuddy logo</h2>
      </div>

      <div class="footer-bottom-links">
        <a href="/policies/shipping-policy">Shipping & Returns</a>
        <a href="/policies/privacy-policy">Privacy Policy</a>
        <span>&copy; {{ 'now' | date: '%Y' }} backupbuddy</span>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Quick links",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "default": true,
      "label": "t:sections.footer.settings.newsletter_enable.label"
    },
    {
      "type": "inline_richtext",
      "id": "newsletter_heading",
      "default": "Sign up to our mailing list to <strong>stay powered.</strong>",
      "label": "t:sections.footer.settings.newsletter_heading.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    }
  ]
}
{% endschema %}