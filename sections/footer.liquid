{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- style -%}
  @font-face {
    font-family: 'Chillax-Custom';
    src: url({{ 'Chillax-Variable.woff2' | asset_url }}) format('woff2');
    font-weight: 100 900;
    font-display: swap;
  }

  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    background-color: #1c1c1c; 
    color: #ffffff;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  /* Standardize the horizontal alignment for all rows */
  .footer__content-top.page-width,
  .footer__content-bottom-wrapper.page-width {
    max-width: 100% !important;
    padding-left: 5rem; /* This sets the "Vertical Line" on the left */
    padding-right: 5rem;
    margin: 0;
    display: flex;
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .footer__content-top.page-width {
      justify-content: flex-start;
      gap: 10rem;
    }

    .footer-block--newsletter {
      flex: 0 0 auto;
      width: 50%; /* Limits newsletter width */
      margin: 0 !important;
      padding: 0 !important;
    }

    .footer__blocks-wrapper {
      flex: 1;
      display: grid;
      grid-template-columns: repeat(2, 1fr); 
      gap: 4rem;
    }
  }

  /* HEADING STYLE */
  .footer-block__heading {
    font-family: 'Chillax-Custom', sans-serif !important;
    font-size: 5.6rem;
    line-height: 1;
    font-weight: 300; 
    letter-spacing: -2px;
    margin: 0 0 4rem 0;
    text-align: left;
  }

  .footer-block__heading strong {
    font-weight: 700; 
  }

  /* INPUT FIELD - CLEAN UNDERLINE ONLY */
  .footer .field {
    max-width: 450px; /* Keeps input from getting too long on wide screens */
  }

  .footer .field:after, .footer .field:before {
    display: none !important;
  }

  .footer .field__input {
    border: none !important;
    border-bottom: 1px solid #ffffff !important;
    background: transparent !important;
    border-radius: 0 !important;
    padding: 1rem 0 !important;
    box-shadow: none !important;
    color: white;
    font-size: 1.6rem;
  }

  .footer .field__label {
    left: 0 !important;
    top: 1rem !important;
  }

  .footer .newsletter-form__button {
    right: 0 !important;
    top: 0 !important;
    height: 100% !important;
    margin: 0 !important;
  }

  /* SUBTEXT ALIGNMENT */
  .newsletter-subtext {
    margin-top: 2rem;
    opacity: 0.6;
    font-style: italic;
    font-size: 1.3rem;
    text-align: left;
  }

  /* BOTTOM AREA ALIGNMENT */
  .footer__content-bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    margin-top: 10rem;
    padding: 6rem 0;
  }

  .footer__content-bottom-wrapper {
    justify-content: space-between; /* Pushes Logo left, Links right */
    align-items: center;
  }

  .footer-custom-logo h2 {
    font-family: 'Chillax-Custom', sans-serif !important;
    font-size: 4.2rem;
    margin: 0;
    font-weight: 400;
    letter-spacing: -2px;
  }

  .footer-bottom-links {
    display: flex;
    gap: 4rem;
    font-size: 1.4rem;
    opacity: 0.8;
    justify-content: flex-end; /* Snaps links to the right */
  }

  .footer-bottom-links a {
    color: inherit;
    text-decoration: none;
    white-space: nowrap;
  }

  /* MENU LINKS */
  .footer-block__heading-small {
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    opacity: 0.4;
    margin-bottom: 2rem;
  }

  .footer-block__details-content .list-menu__item--link {
    font-weight: 500;
    font-size: 1.7rem;
    padding: 0.6rem 0;
    color: #fff;
  }

{%- endstyle -%}

<footer class="footer color-{{ section.settings.color_scheme }} gradient">
  <div class="footer__content-top page-width section-{{ section.id }}-padding">
    
    {%- if section.settings.newsletter_enable -%}
      <div class="footer-block--newsletter">
        {%- if section.settings.newsletter_heading != blank -%}
          <h2 class="footer-block__heading inline-richtext">{{ section.settings.newsletter_heading }}</h2>
        {%- endif -%}
        
        {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="newsletter-form__field-wrapper">
            <div class="field">
              <input
                id="NewsletterForm--{{ section.id }}"
                type="email"
                name="contact[email]"
                class="field__input"
                value="{{ form.email }}"
                aria-required="true"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                placeholder="Email address*"
                required
              >
              <label class="field__label" for="NewsletterForm--{{ section.id }}">Email address*</label>
              <button type="submit" class="newsletter-form__button field__button" name="commit" id="Subscribe">
                <span class="svg-wrapper">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </button>
            </div>
            <p class="newsletter-subtext">Enjoy 10% off your first purchase on sign up</p>
          </div>
        {%- endform -%}
      </div>
    {%- endif -%}

    <div class="footer__blocks-wrapper grid">
      {%- for block in section.blocks -%}
        <div class="footer-block grid__item" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <p class="footer-block__heading-small">{{- block.settings.heading -}}</p>
          {%- endif -%}

          {%- case block.type -%}
            {%- when 'link_list' -%}
              {%- if block.settings.menu != blank -%}
                <ul class="footer-block__details-content list-unstyled">
                  {%- for link in block.settings.menu.links -%}
                    <li>
                      <a href="{{ link.url }}" class="link link--text list-menu__item list-menu__item--link">
                        {{ link.title | escape }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>
  </div>

  <div class="footer__content-bottom">
    <div class="footer__content-bottom-wrapper page-width">
      <div class="footer-custom-logo">
        <h2>backupbuddy logo</h2>
      </div>

      <div class="footer-bottom-links">
        <a href="/policies/shipping-policy">Shipping & Returns</a>
        <a href="/policies/privacy-policy">Privacy Policy</a>
        <span>&copy; {{ 'now' | date: '%Y' }} backupbuddy</span>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [
    {
      "type": "link_list",
      "name": "Link list",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Quick links",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Menu"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "default": true,
      "label": "Show newsletter"
    },
    {
      "type": "inline_richtext",
      "id": "newsletter_heading",
      "default": "Sign up to our mailing list to <strong>stay powered.</strong>",
      "label": "Newsletter heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    }
  ]
}
{% endschema %}