{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- style -%}
  @font-face {
    font-family: 'Chillax-Custom';
    src: url({{ 'Chillax-Variable.woff2' | asset_url }}) format('woff2');
    font-weight: 100 900;
    font-display: swap;
  }

  .footer {
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    background-color: #1c1c1c !important; 
    color: #ffffff !important;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  /* Force the Vertical Alignment Line */
  .footer__content-top.page-width,
  .footer__content-bottom-wrapper.page-width {
    max-width: 100% !important;
    margin: 0 !important;
    padding-left: 5rem !important; 
    padding-right: 5rem !important;
    display: flex !important;
    width: 100% !important;
  }

  @media screen and (min-width: 750px) {
    .footer__content-top.page-width {
      justify-content: flex-start !important;
      align-items: flex-start !important;
    }

    .footer-block--newsletter {
      flex: 0 0 50% !important;
      text-align: left !important;
      margin: 0 !important;
      padding: 0 !important;
    }

    .footer__blocks-wrapper {
      flex: 1;
      display: grid;
      grid-template-columns: repeat(2, 1fr); 
      gap: 4rem;
    }
  }

  /* TEXT COLORS & FONTS */
  .footer h2, 
  .footer p, 
  .footer span, 
  .footer a, 
  .footer .field__input, 
  .footer .field__label {
    color: #ffffff !important;
  }

  /* --- THE FIX FOR THE VARIABLE FONT WEIGHT --- */
  .footer-block__heading {
    font-family: 'Chillax-Custom', sans-serif !important;
    font-size: 5.6rem !important;
    line-height: 1.1 !important;
    font-weight: 300 !important; /* Fallback */
    font-variation-settings: 'wght' 300 !important; /* Forces variable font to be thin */
    letter-spacing: -2px !important;
    margin-bottom: 4rem !important;
    text-transform: none !important;
  }

  .footer-block__heading strong,
  .footer-block__heading b {
    font-weight: 700 !important; /* Fallback */
    font-variation-settings: 'wght' 700 !important; /* Forces variable font to be thick */
  }
  /* -------------------------------------------- */

  .footer .footer-block__newsletter {
    text-align: left !important;
    display: flex;
    flex-direction: column;
    align-items: flex-start !important;
  }

  .footer .newsletter-form {
    margin-left: 0 !important;
    margin-right: auto !important;
    max-width: 100% !important;
    display: flex;
    flex-direction: column;
    align-items: flex-start !important;
  }

  .footer .newsletter-form__field-wrapper {
    max-width: 450px !important;
    width: 100% !important;
    margin-left: 0 !important;
  }

  .footer .field {
    width: 100% !important;
    margin: 0 !important; 
  }

  .footer .field:after, .footer .field:before {
    display: none !important;
  }

  .footer .field__input {
    border: none !important;
    border-bottom: 1px solid #ffffff !important;
    background: transparent !important;
    border-radius: 0 !important;
    padding: 1rem 0 !important;
    box-shadow: none !important;
    font-size: 1.6rem;
  }

  .newsletter-subtext {
    margin-top: 2rem;
    opacity: 0.6;
    font-style: italic;
    font-size: 1.3rem;
    text-align: left !important;
    width: 100%;
  }

  /* BOTTOM AREA LOCK */
  .footer__content-bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    margin-top: 10rem;
    padding: 6rem 0;
  }

  .footer__content-bottom-wrapper {
    justify-content: space-between !important;
  }

  .footer-custom-logo h2 {
    font-family: 'Chillax-Custom', sans-serif !important;
    font-size: 4.2rem !important;
    margin: 0 !important;
    font-weight: 400 !important;
    font-variation-settings: 'wght' 400 !important;
    letter-spacing: -2px !important;
    color: #ffffff !important;
  }

  .footer-bottom-links {
    display: flex;
    gap: 4rem;
    font-size: 1.4rem;
    opacity: 0.8;
  }

  .footer-bottom-links a {
    text-decoration: none;
    white-space: nowrap;
  }

{%- endstyle -%}

<footer class="footer">
  <div class="footer__content-top page-width section-{{ section.id }}-padding">
    
    {%- if section.settings.newsletter_enable -%}
      <div class="footer-block--newsletter">
        <div class="footer-block__newsletter">
          {%- if section.settings.newsletter_heading != blank -%}
            <h2 class="footer-block__heading">{{ section.settings.newsletter_heading }}</h2>
          {%- endif -%}
          
          {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="newsletter-form__field-wrapper">
              <div class="field">
                <input
                  id="NewsletterForm--{{ section.id }}"
                  type="email"
                  name="contact[email]"
                  class="field__input"
                  value="{{ form.email }}"
                  placeholder="Email address*"
                  required
                >
                <label class="field__label" for="NewsletterForm--{{ section.id }}">Email address*</label>
                <button type="submit" class="newsletter-form__button field__button" name="commit" id="Subscribe">
                  <span class="svg-wrapper">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </button>
              </div>
              <p class="newsletter-subtext">Enjoy 10% off your first purchase on sign up</p>
            </div>
          {%- endform -%}
        </div>
      </div>
    {%- endif -%}

    <div class="footer__blocks-wrapper">
      {%- for block in section.blocks -%}
        <div class="footer-block" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <p style="font-size: 1.2rem; text-transform: uppercase; opacity: 0.4; margin-bottom: 2rem;">{{- block.settings.heading -}}</p>
          {%- endif -%}

          {%- if block.settings.menu != blank -%}
            <ul class="list-unstyled">
              {%- for link in block.settings.menu.links -%}
                <li style="margin-bottom: 1rem;">
                  <a href="{{ link.url }}" style="font-size: 1.7rem; font-weight: 500; text-decoration: none;">
                    {{ link.title | escape }}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>

  <div class="footer__content-bottom">
    <div class="footer__content-bottom-wrapper page-width">
      <div class="footer-custom-logo">
        <h2>backupbuddy logo</h2>
      </div>

      <div class="footer-bottom-links">
        <a href="/policies/shipping-policy">Shipping & Returns</a>
        <a href="/policies/privacy-policy">Privacy Policy</a>
        <span>&copy; {{ 'now' | date: '%Y' }} backupbuddy</span>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer Custom",
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "default": true,
      "label": "Show newsletter"
    },
    {
      "type": "html",
      "id": "newsletter_heading",
      "default": "Sign up to our<br>mailing list to<br><strong>stay powered.</strong>",
      "label": "Newsletter heading (Use <br> for line breaks)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    }
  ]
}
{% endschema %}